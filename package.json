{
  "name": "family-atlas-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply family-atlas --local",
    "db:migrate:remote": "wrangler d1 migrations apply family-atlas --remote",
    "db:studio": "drizzle-kit studio",
    "dev:pages": "wrangler pages dev ./dist --local-protocol=http",
    "deploy": "npm run build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1",
    "vite": "latest"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "optionalDependencies": {
    "@cloudflare/workerd-windows-64": "^1.20260715.1"
  }
}
